{
  "manifest_version": 3,
  "name": "Only Post",
  "version": "1.1",
  "description": "Limit Twitter(X) usage to Profile/Posting. / プロフィールと投稿以外に制限をかけるFocus拡張機能。",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["*://*.twitter.com/*", "*://*.x.com/*"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ]
}
